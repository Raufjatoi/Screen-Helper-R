{
  "manifest_version": 3,
  "name": "Screen Helper R",
  "version": "1.0",
  "description": "Screen Helper extension for snipping elements, blurring, and screen recording.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabCapture",
    "offscreen",
    "storage",
    "downloads",
    "desktopCapture"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/selector.css"],
      "js": ["content/restore.js", "content/timer.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/selector.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
